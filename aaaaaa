    const tbody = document.getElementById('companyProductsBody');
    if (!tbody) return;
    
    if (!loggedInCompany.products || loggedInCompany.products.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="5" style="text-align: center; padding: 30px;">
                    <i class="fas fa-box-open" style="font-size: 48px; color: #ccc;"></i>
                    <p>Nuk keni asnjë produkt ende. Shtoni produktin tuaj të parë!</p>
                    <button class="btn btn-primary" onclick="showAddProductForm()" style="margin-top: 10px;">
                        <i class="fas fa-plus"></i> Shto Produktin e Parë
                    </button>
                </td>
            </tr>
        `;
        return;
    }
    
    let html = '';
    loggedInCompany.products.forEach(product => {
        html += `
            <tr>
                <td><strong>${product.name}</strong></td>
                <td>€${typeof product.price === 'number' ? product.price.toFixed(2) : product.price}</td>
                <td>${product.unit || '-'}</td>
                <td>${product.features ? (Array.isArray(product.features) ? product.features.join(', ') : product.features) : '-'}</td>
                <td>
                    <button class="action-btn edit-btn" onclick="editProduct(${product.id})">
                        <i class="fas fa-edit"></i> Ndrysho
                    </button>
                    <button class="action-btn delete-btn" onclick="deleteProduct(${product.id})">
                        <i class="fas fa-trash"></i> Fshi
                    </button>
                </td>
            </tr>
        `;
    });
    
    tbody.innerHTML = html;
}

// Show add product form
function showAddProductForm() {
    const form = document.getElementById('addProductForm');
    if (form) {
        form.style.display = 'block';
        form.scrollIntoView({ behavior: 'smooth' });
    }
}

// Hide add product form
function hideAddProductForm() {
    const form = document.getElementById('addProductForm');
    if (form) {
        form.style.display = 'none';
    }
    
    const productForm = document.getElementById('productRegistrationForm');
    if (productForm) {
        productForm.reset();
        delete productForm.dataset.editingId;
        
        const submitBtn = productForm.querySelector('button[type="submit"]');
        if (submitBtn) {
            submitBtn.innerHTML = '<i class="fas fa-save"></i> Ruaje Produktin';
        }
    }
}

// Add or update product
async function addNewProduct(e) {
    e.preventDefault();
    
    const featuresInput = document.getElementById('productFeatures').value;
    let features = [];
    
    if (featuresInput) {
        features = featuresInput.split(',')
            .map(f => f.trim())
            .filter(f => f !== '');
    }
    

         const selectedSector = document.getElementById('productSector').value;
    



const productData = {
    id: Date.now(),
    name: document.getElementById('productName').value,
    price: parseFloat(document.getElementById('productPrice').value),
    unit: document.getElementById('productUnit').value,
    sector: document.getElementById('productSector').value,   // KJO MUNGON
    features: features,
    description: document.getElementById('productDescription').value,
    category: document.getElementById('productCategory').value,
    stock: document.getElementById('productStock').value || '0',
    image: 'fa-solid fa-box'
};
    
    const form = document.getElementById('productRegistrationForm');
    const editingId = form.dataset.editingId;
    
    if (editingId) {
        // EDITIM
        const index = loggedInCompany.products.findIndex(p => p.id == editingId);
        if (index !== -1) {
            productData.id = parseInt(editingId);
            loggedInCompany.products[index] = productData;
        }
        
        delete form.dataset.editingId;
        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) {
            submitBtn.innerHTML = '<i class="fas fa-save"></i> Ruaje Produktin';
        }
        
        showSuccessMessage('Produkti u përditësua me sukses!');
    } else {
        // SHTIM I RI
        if (!loggedInCompany.products) {
            loggedInCompany.products = [];
        }
        loggedInCompany.products.push(productData);
        showSuccessMessage('Produkti u shtua me sukses!');
    }
    
    // Përditëso kompaninë në API
    const companyIndex = companiesData.findIndex(c => c.id === loggedInCompany.id);
    if (companyIndex !== -1) {
        companiesData[companyIndex] = {...loggedInCompany};
        await updateCompanyInAPI(loggedInCompany);
    }
    
    loggedInCompany = companiesData.find(c => c.id === loggedInCompany.id);
    
    loadCompanyProducts();
    hideAddProductForm();
    displayCompaniesDirectory();
}

// Delete product
window.deleteProduct = async function(productId) {
    if (confirm('Jeni i sigurt që doni të fshini këtë produkt?')) {
        loggedInCompany.products = loggedInCompany.products.filter(p => p.id !== productId);
        
        const companyIndex = companiesData.findIndex(c => c.id === loggedInCompany.id);
        if (companyIndex !== -1) {
            companiesData[companyIndex] = {...loggedInCompany};
            await updateCompanyInAPI(loggedInCompany);
        }
        
        loadCompanyProducts();
        displayCompaniesDirectory();
        
        showSuccessMessage('Produkti u fshi!');
    }
};

// Edit product
window.editProduct = function(productId) {
    const product = loggedInCompany.products.find(p => p.id === productId);
    
    if (product) {
        document.getElementById('productName').value = product.name || '';
        document.getElementById('productPrice').value = product.price || '';
        document.getElementById('productUnit').value = product.unit || '';
        document.getElementById('productCategory').value = product.category || '';
        
        if (product.features) {
            const featuresText = Array.isArray(product.features) 
                ? product.features.join(', ') 
                : product.features;
            document.getElementById('productFeatures').value = featuresText;
        } else {
            document.getElementById('productFeatures').value = '';
        }
        
        document.getElementById('productDescription').value = product.description || '';
        document.getElementById('productStock').value = product.stock || '';
        
        const form = document.getElementById('productRegistrationForm');
        const submitBtn = form.querySelector('button[type="submit"]');
        
        form.dataset.editingId = productId;
        
        if (submitBtn) {
            submitBtn.innerHTML = '<i class="fas fa-save"></i> Përditëso Produktin';
        }
        
        showAddProductForm();
    }
};

// ==================== FUNKSIONET NDIHMËSE ====================

// Show success message
function showSuccessMessage(message) {
    const msgDiv = document.createElement('div');
    msgDiv.className = 'success-message';
    msgDiv.innerHTML = `
        <i class="fas fa-check-circle"></i>
        ${message}
    `;
    
    document.body.appendChild(msgDiv);
    
    setTimeout(() => {
        msgDiv.remove();
    }, 3000);
}

// Show error message
function showErrorMessage(message) {
    const msgDiv = document.createElement('div');
    msgDiv.className = 'error-message';
    msgDiv.innerHTML = `
        <i class="fas fa-exclamation-circle"></i>
        ${message}
    `;
    
    document.body.appendChild(msgDiv);
    
    setTimeout(() => {
        msgDiv.remove();
    }, 4000);
}

// Check email availability
function checkEmailAvailability() {
    const email = document.getElementById('companyEmail').value;
    const emailField = document.getElementById('companyEmail');
    const existingCompany = companiesData.find(c => c.email.toLowerCase() === email.toLowerCase());
    
    if (existingCompany) {
        emailField.style.borderColor = 'red';
        
        let availabilityMsg = document.getElementById('emailAvailabilityMsg');
        if (!availabilityMsg) {
            availabilityMsg = document.createElement('small');
            availabilityMsg.id = 'emailAvailabilityMsg';
            availabilityMsg.style.color = 'red';
            emailField.parentNode.appendChild(availabilityMsg);
        }
        availabilityMsg.textContent = 'Ky email është i zënë';
    } else {
        emailField.style.borderColor = 'green';
        
        let availabilityMsg = document.getElementById('emailAvailabilityMsg');
        if (availabilityMsg) {
            availabilityMsg.textContent = 'Email i lirë';
            availabilityMsg.style.color = 'green';
        }
    }
}

// Add smooth scrolling for navigation links
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
            target.scrollIntoView({ behavior: 'smooth' });
        }
    });
});










